# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Your Supabase auth user UUID (profiles.id). Required for preview/public site to show the same
# hero_text, projects, and settings you edit while signed in. Find: Supabase → Authentication → Users.
VITE_PUBLIC_PORTFOLIO_OWNER_ID=

# Email for the site owner sign-in modal (must match your Supabase Auth user). Required for edit mode.
# CMS / edit mode / messages require a real Supabase session — not localStorage-only flags.
# This is also the default public contact mailto (e.g. your Gmail) unless VITE_PUBLIC_CONTACT_EMAIL is set.
VITE_SITE_OWNER_SIGNIN_EMAIL=

# Optional: public contact email (footer mailto, Contact page default). Defaults to VITE_SITE_OWNER_SIGNIN_EMAIL if unset.
# VITE_PUBLIC_CONTACT_EMAIL=

# Optional: public favicon image URL (e.g. Supabase Storage public URL). Overrides DB when set.
# VITE_PUBLIC_FAVICON_URL=

# --- Production launch (Vercel) ---
# Set all VITE_* vars above in Project → Settings → Environment Variables for Production (and Preview if needed).
# Redeploy after changing env vars (Vite inlines them at build time).
# Run pending supabase/migrations on your hosted project (CLI or SQL Editor), including 0033 (project RPCs) and 0034 (storage).

# Example:
# VITE_SUPABASE_URL=https://your-project-id.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
